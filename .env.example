# Development-only bearer identities for the private API.
# Never commit real tokens. Replace every UUID and token locally.
# The value must remain on one line when exported by your shell.
ASTRYNN_API_TOKENS_JSON=[{"token":"replace-with-long-random-token","actor_id":"00000000-0000-0000-0000-000000000001","organization_id":"00000000-0000-0000-0000-000000000010","role":"SYSTEM_ADMIN","display_name":"Local system administrator"}]

# Leave empty to use the ephemeral in-memory repository.
# Local persistent development example:
ASTRYNN_DATABASE_URL=sqlite:///./astrynn-dev.db

# Safe for local SQLite only. Keep false for PostgreSQL/Supabase and apply reviewed migrations.
ASTRYNN_AUTO_CREATE_SCHEMA=true

# PostgreSQL/Supabase shape only. Never commit the real credential:
# ASTRYNN_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres?sslmode=require
